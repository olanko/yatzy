# Production environment variables. Copy to .env on the server
# (read by scripts/remote_deploy.sh) and edit. Never commit the
# real .env to git.

# Required.
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Absolute path to the SQLite database file.
DATABASE_PATH=

# Public hostname or IP — must match the TLS cert / nginx server_name.
PHX_HOST=

# Optional. Defaults: PORT=4000, POOL_SIZE=5.
PORT=
POOL_SIZE=
